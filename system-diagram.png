      "versionNonce": 649804121,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1780327338500,
      "link": null,
      "locked": false,
      "text": "- valkey is defined in a separate valkey/docker-compose.yml and is not shown here\n— the api connects to it via the Redis protocol (TCP 6379)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- valkey is defined in a separate valkey/docker-compose.yml and is not shown here — the api connects to it via the Redis protocol (TCP 6379)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
