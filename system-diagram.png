      "boundElements": null,
      "updated": 1780327338500,
      "link": null,
      "locked": false,
      "text": "- client has no depends_on declared in the compose file, but at runtime it makes\nHTTP requests to api:8000 for all data",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- client has no depends_on declared in the compose file, but at runtime it makes HTTP requests to api:8000 for all data",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ducD6o4vKiex8_uPWm0VI",
      "type": "text",
      "x": 167.58029174804688,
      "y": 283,
      "width": 796.8394165039062,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
